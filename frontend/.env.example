# ──────────────────────────────────────────────
# HRHub Frontend — Environment Variables
# Copy to .env.local and fill in values
# ──────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# Leave empty in local dev to use the Vite proxy (avoids CORS entirely).
# Set to the deployed backend URL in production, e.g.:
#   VITE_API_URL=https://your-backend.up.railway.app/api/v1
VITE_API_URL=

# App name (used in page titles)
VITE_APP_NAME=HRHub
