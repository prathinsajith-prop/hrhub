# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://hrhub_user:hrhub_secret@localhost:5432/hrhub

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_to_another_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://:hrhub_redis_secret@localhost:6379

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173

# File Storage (S3 / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=hrhub-documents
S3_ACCESS_KEY=erp_minio
S3_SECRET_KEY=erp_minio_password
S3_PUBLIC_URL=http://localhost:9001/hrhub-documents

# Email (Gmail via App Password)
EMAIL_PROVIDER=gmail
RESEND_API_KEY=
GMAIL_USER=sprathin007@gmail.com
GMAIL_APP_PASSWORD=XXXXXXXXXXXXXX
EMAIL_FROM=sprathin007@gmail.com
EMAIL_FROM_NAME=HRHub
EMAIL_DEV_FALLBACK=false

# Stripe — required for self-service Professional plan checkout
# Leave empty to fall back to the email-request upgrade flow
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...