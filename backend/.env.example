# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://hrhub_user:hrhub_secret@localhost:5432/hrhub

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=change_me_to_another_long_random_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://:hrhub_redis_secret@localhost:6379

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173

# File Storage (S3 / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=hrhub-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Email
# EMAIL_PROVIDER: smtp | resend | gmail
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@hrhub.ae
EMAIL_FROM_NAME=HRHub
# SMTP (Mailpit dev / SES / etc.)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# Resend
RESEND_API_KEY=
# Gmail (use a Google App Password, NOT your account password)
GMAIL_USER=
GMAIL_APP_PASSWORD=
# When true, dev environments swallow transport errors and return success
EMAIL_DEV_FALLBACK=false

# Stripe — required for self-service Professional plan checkout
# Leave empty to fall back to the email-request upgrade flow
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
